# ============================================
# TRELLO.NUNEX.LAT → Redirige a Trello.com
# ============================================
trello.nunex.lat {
    redir https://trello.com{uri} permanent
}

# ============================================
# TRELLO.SMARTERPROP.CL - Focalboard + Odoo
# ============================================
trello.smarterprop.cl {
    reverse_proxy trello-smarterprop:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-Proto "https"
    }
    encode gzip
    log {
        output file /var/log/caddy/trello-smarterprop-access.log
        level INFO
    }
}

# ============================================================
# SERVICIOS INTERNOS (NO EXPONER - SOLO SSH TUNNEL)
# ============================================================
# Grafana:     ssh -L 3000:localhost:3000 root@vps → http://localhost:3000
# Prometheus:  ssh -L 9090:localhost:9090 root@vps → http://localhost:9090
# cAdvisor:    ssh -L 9091:localhost:9091 root@vps → http://localhost:9091
# ============================================================

