# ============================================================
# CADDYFILE - SMARTERBOT.CL PRODUCTION
# Solo servicios REALES + PÚBLICOS
# Grafana/Prometheus = SOLO SSH TUNNEL
# ============================================================

# ============================================
# API.SMARTERBOT.CL - Gateway Principal
# ============================================
api.smarterbot.cl {
    reverse_proxy smarteros-api-mcp:3000
    encode gzip
    log {
        output file /var/log/caddy/api-access.log
        level INFO
    }
}

# ============================================
# BI.SMARTERBOT.CL - Command Center Dashboard
# ============================================
bi.smarterbot.cl {
    reverse_proxy smarteros-bi-dashboard:3001
    encode gzip
    log {
        output file /var/log/caddy/bi-access.log
        level INFO
    }
}

# ============================================
# WEBHOOK - Auto-deploy endpoint
# ============================================
bi.smarterbot.cl/api/webhook {
    reverse_proxy bi-webhook-server:8089
    encode gzip
    log {
        output file /var/log/caddy/webhook-access.log
        level INFO
    }
}

# ============================================
